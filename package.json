{
  "name": "pmm-smart-contract",
  "version": "1.0.0",
  "description": "Pythagorean Market Maker Smart Contracts",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:v2": "hardhat test test/hardhat/pmmV2.*.test.js",
    "test:pmm": "hardhat test test/hardhat/pmmV2.pmm.test.js",
    "test:proof": "hardhat test test/hardhat/pmmV2.proof.test.js",
    "test:tbn": "hardhat test test/hardhat/pmmV2.tbn.test.js",
    "test:fees": "hardhat test test/hardhat/pmmV2.fees.test.js",
    "test:security": "hardhat test test/hardhat/pmmV2.security.test.js",
    "test:frontrun": "hardhat test test/hardhat/pmmV2.frontrun.test.js",
    "test:lategame": "hardhat test test/hardhat/pmmV2.lategame.test.js",
    "test:integration": "hardhat test test/hardhat/pmmV2.integration.test.js",
    "test:foundry": "forge test",
    "test:all": "npm run test:v2 && npm run test:foundry",
    "deploy:v2:mainnet": "hardhat run scripts/deploy-v2-mainnet.js --network mainnet",
    "node": "hardhat node --hostname 0.0.0.0",
    "check:v2": "hardhat run scripts/check-v2-status.js"
  },
  "keywords": ["blockchain", "ethereum", "smart-contracts", "reputation", "pythagorean"],
  "author": "Calvin Lin (cl@bittenbin.com)",
  "license": "SEE LICENSE IN licenses/BUSL_LICENSE",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.2",
    "@nomicfoundation/hardhat-ethers": "^3.0.5",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.10",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.3",
    "@openzeppelin/hardhat-upgrades": "^3.0.2",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.5",
    "chai": "^4.3.10",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "hardhat": "^2.19.3",
    "hardhat-gas-reporter": "^1.0.9",
    "solidity-coverage": "^0.8.5",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.1",
    "@openzeppelin/contracts-upgradeable": "^5.0.1"
  }
}