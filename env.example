# Private key for deployment (without 0x prefix)
PRIVATE_KEY=

# RPC URLs
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR-API-KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR-API-KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR-API-KEY

# API Keys for verification
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# Contract Configuration
# USDC payment token (required)
PAYMENT_TOKEN_USDC=
# TENBIN reward token (optional if DEPLOY_TENBIN=true)
REWARD_TOKEN_TENBIN=0x420331D6396B7290B57Ac4633983FC9a95F9913C
# Set true to deploy a TENBIN token and use it as reward token
DEPLOY_TENBIN=true

# Proxy addresses (for upgrades and scripts)
PMM_PROXY_ADDRESS=0x92AcC35FE215a065146F93132cF27D5C3E39D826
PMM_IMPLEMENTATION_ADDRESS=

# Fee Recipients (optional - defaults are set in contract)
# OWNER_FEE_RECIPIENT=0x2dfc776B09234f617DFc38Cb8De1BB2B0B7C4E5B
# PROTOCOL_FEE_RECIPIENT=0xb322A547De3308C2426aEa700c8176574E57eEe6

# Optional: Gas reporting
REPORT_GAS=false
COINMARKETCAP_API_KEY=

# Optional: Fork configuration
# FORK_URL=
# FORK_BLOCK_NUMBER= 